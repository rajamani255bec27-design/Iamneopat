#include<iostream>
using namespace std;
int main(){
    int n;
    cin>>n;
    if(n<=0){
        cout<<"Invalid";
        return 0;
    }
    long long sum=0;
    long long product=1;
    int val;
    for(int i=0;i<n;i++){
        cin>>val;
        sum+=val;
        product*=val;
    }
    cout<<"Sum:"<<sum<<endl;
    cout<<"Product:"<<product;
    return 0;
}
