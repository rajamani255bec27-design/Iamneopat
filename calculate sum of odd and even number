#include<iostream>
#include<string>
using namespace std;
int main(){
    string n;
    cin>>n;
    int sumodd=0,sumeven=0;
    for(char digitchar:n){
        int digit=digitchar - '0';
        if(digit%2==0){
            sumeven+=digit;
        }
        else{
            sumodd+=digit;
        }
        
    }
    cout<<sumodd<<" "<<sumeven;
    return 0;
}
